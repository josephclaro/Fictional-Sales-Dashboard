    <worksheet name='pareto'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='10'>Pareto</run>
            <run fontsize='10'><![CDATA[ - <[Parameters].[Parameter 1]> ($<[federated.1s19hh501nv53g161b6781sh74ex].[sum:Calculation_2982227408659886093:qk]>  / $<[federated.1s19hh501nv53g161b6781sh74ex].[sum:Calculation_2982227408659439628:qk]>) of sales ]]></run>
            <run fontcolor='#000000' fontsize='10'>shown in </run>
            <run bold='true' fontcolor='#90a832' fontsize='10'>green</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Products+ (Financials (2))' name='federated.1s19hh501nv53g161b6781sh74ex' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Target Sales Pct' datatype='real' default-format='p0.00%' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='0.81000000000000005'>
              <calculation class='tableau' formula='0.81000000000000005' />
              <range granularity='0.01' max='1.0' min='0.0' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1s19hh501nv53g161b6781sh74ex'>
            <column caption='Target Customer Pct' datatype='integer' name='[Calculation_1115203898426474498]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_SUM(IF RUNNING_SUM(SUM([Sales ($)])) / WINDOW_SUM(SUM([Sales ($)]))&#13;&#10;    &lt;= [Parameters].[Parameter 1]&#13;&#10;THEN 1&#13;&#10;END)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Target No. Customers' datatype='integer' name='[Calculation_1115203898438660102]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_COUNT(IF [Calculation_2982227411112681486] THEN 1 END)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Total Customers' datatype='integer' name='[Calculation_2982227408656863242]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ COUNT(ID) }' />
            </column>
            <column caption='Total Sales' datatype='real' name='[Calculation_2982227408659439628]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ Sum([Sales ($)]) }' />
            </column>
