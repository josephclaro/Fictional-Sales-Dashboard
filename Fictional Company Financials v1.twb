      </column>
      <column caption='Target Sales' datatype='real' name='[Calculation_2982227408659886093]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2982227408659439628] * [Parameters].[Parameter 1]' />
      </column>
      <column caption='Within Range' datatype='boolean' name='[Calculation_2982227411112681486]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales ($)])) / TOTAL(SUM([Sales ($)])) &lt;= [Parameters].[Parameter 1]'>
